              "id": "IN-R010",
              "priority": "P0",
              "area": "Adapters",
              "text": "The Claude adapter shall invoke claude CLI in a specified working directory. It shall support session resume via --session-id and prompt injection via --prompt or stdin.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [
                "T-602"
