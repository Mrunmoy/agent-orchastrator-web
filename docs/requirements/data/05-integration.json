    {
      "title": "MCP (Model Context Protocol)",
      "subsections": [
        {
          "title": "MCP Integration",
          "requirements": [
            {
              "id": "IN-R050",
              "priority": "P1",
              "area": "MCP",
              "text": "The system shall evaluate MCP as an alternative or complement to direct CLI adapters. If MCP provides a standardized way to communicate with agent CLIs, the adapter layer shall be refactored to use MCP transport where beneficial.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [],
              "tests": []
            },
            {
              "id": "IN-R051",
              "priority": "P1",
              "area": "MCP",
              "text": "The backend shall be capable of acting as an MCP client \u2014 connecting to MCP-compatible agent servers to send prompts and receive structured responses.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [],
              "tests": []
            },
            {
              "id": "IN-R052",
              "priority": "P2",
              "area": "MCP",
              "text": "The backend shall be capable of exposing an MCP server \u2014 allowing external MCP clients to interact with the orchestrator's tools (conversation management, task assignment, steering).",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [],
              "tests": []
            },
            {
              "id": "IN-R053",
              "priority": "P1",
              "area": "MCP",
              "text": "MCP integration shall not be a hard dependency. The system shall work with pure CLI adapters. MCP shall be an opt-in enhancement for providers that support it.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [],
              "tests": []
            }
          ]
        }
      ]
    },
    {
      "title": "GitHub Integration",
      "subsections": [
        {
          "title": "Pull Requests",
          "requirements": [
            {
              "id": "IN-R060",
              "priority": "P0",
              "area": "GitHub",
              "text": "The system shall detect when an agent raises a PR (via monitoring git state or parsing agent output). PR metadata (number, URL, branch, title) shall be stored with the task.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [
                "T-607"
              ],
              "tests": [
                {
                  "id": "TT-607-01",
                  "task_id": "T-607",
                  "description": "PR creation detected from agent output containing 'gh pr create' results",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                },
                {
                  "id": "TT-607-02",
                  "task_id": "T-607",
                  "description": "PR metadata (number, URL, branch, title) correctly extracted",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                },
                {
                  "id": "TT-607-03",
                  "task_id": "T-607",
                  "description": "Task record updated with PR reference after detection",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                }
              ]
            },
            {
              "id": "IN-R061",
              "priority": "P1",
              "area": "GitHub",
              "text": "The system shall use the GitHub CLI (gh) or GitHub API to: list PRs, read review comments, check CI status, and post review comments. These operations shall be performed by the Team Lead (Ollama) or system process, not paid agents.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [
                "T-608"
              ],
              "tests": [
                {
                  "id": "TT-608-01",
                  "task_id": "T-608",
                  "description": "list_prs() invokes gh pr list and returns structured PR metadata",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                },
                {
                  "id": "TT-608-02",
                  "task_id": "T-608",
                  "description": "get_review_comments() returns parsed review comments for a PR",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                },
                {
                  "id": "TT-608-03",
                  "task_id": "T-608",
                  "description": "check_ci_status() returns correct status (passed, failed, pending)",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                },
                {
                  "id": "TT-608-04",
                  "task_id": "T-608",
                  "description": "post_review() invokes gh pr review with correct arguments",
                  "type": "unit",
                  "file": "backend/tests/test_github_integration.py"
                }
              ]
            }
          ]
        },
