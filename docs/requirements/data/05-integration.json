        {
          "title": "CI Status",
          "requirements": [
            {
              "id": "IN-R080",
              "priority": "P1",
              "area": "GitHub",
              "text": "The system shall poll or receive webhooks for CI status on PRs. CI failures shall be surfaced as task events and the owning agent shall be notified to fix.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [
                "T-609"
              ],
