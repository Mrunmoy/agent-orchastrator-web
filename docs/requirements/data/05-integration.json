        {
          "title": "Ollama Adapter",
          "requirements": [
            {
              "id": "IN-R030",
              "priority": "P0",
              "area": "Adapters",
              "text": "The Ollama adapter shall communicate with a locally running Ollama instance via its HTTP API (http://localhost:11434 by default). No CLI subprocess needed.",
              "status": "done",
              "design_ref": "DES-07",
              "tasks": [
                "T-604"
              ],
              "tests": [
                {
                  "id": "TT-604-01",
                  "task_id": "T-604",
