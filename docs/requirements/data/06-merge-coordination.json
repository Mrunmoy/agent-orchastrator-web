                  "task_id": "T-708",
                  "description": "Response includes timing data (queued_at, merged_at)",
                  "type": "unit",
                  "file": "backend/tests/test_merge_api.py"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Merge Process",
      "subsections": [
        {
          "title": "Process",
          "requirements": [
            {
              "id": "MG-R010",
              "priority": "P0",
              "area": "Process",
              "text": "When a PR reaches the front of the queue, the merge process shall: 1) Rebase the PR branch onto latest main. 2) Run tests (if CI is configured). 3) If tests pass, merge (squash or regular, configurable). 4) If tests fail, move PR to fixing_comments and notify the author agent.",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-702"
              ],
              "tests": [
                {
                  "id": "TT-702-01",
                  "task_id": "T-702",
                  "description": "Clean rebase advances PR status from rebasing to testing",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-02",
                  "task_id": "T-702",
                  "description": "Rebase conflict marks PR as blocked and emits notification",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-03",
                  "task_id": "T-702",
                  "description": "CI pass triggers merge with configured strategy (squash default)",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-04",
                  "task_id": "T-702",
                  "description": "While one PR is merging, no other PR can enter rebasing/testing/merging",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                }
              ]
            },
            {
              "id": "MG-R011",
              "priority": "P0",
              "area": "Process",
              "text": "While one PR is merging, all other agents shall be blocked from pushing to main. They may continue working on their branches but shall not attempt to merge.",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-702"
              ],
              "tests": [
                {
                  "id": "TT-702-01",
                  "task_id": "T-702",
                  "description": "Clean rebase advances PR status from rebasing to testing",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-02",
                  "task_id": "T-702",
                  "description": "Rebase conflict marks PR as blocked and emits notification",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-03",
                  "task_id": "T-702",
                  "description": "CI pass triggers merge with configured strategy (squash default)",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-702-04",
                  "task_id": "T-702",
                  "description": "While one PR is merging, no other PR can enter rebasing/testing/merging",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                }
              ]
            },
            {
              "id": "MG-R012",
              "priority": "P0",
              "area": "Process",
              "text": "After a successful merge, the system shall: 1) Notify the next PR in queue to begin its rebase. 2) Notify all other agents with open PRs that main has changed. 3) Update the task status to done. 4) Clean up the merged worktree and branch.",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-707"
              ],
              "tests": [
                {
                  "id": "TT-707-01",
                  "task_id": "T-707",
                  "description": "main_updated event is broadcast to all conversation agents after merge",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-707-02",
                  "task_id": "T-707",
                  "description": "Next PR in queue is triggered immediately (no 30s polling delay)",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-707-03",
                  "task_id": "T-707",
                  "description": "Merged task status set to done and worktree cleaned up",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                },
                {
                  "id": "TT-707-04",
                  "task_id": "T-707",
                  "description": "Merge events are logged as message_event entries for audit trail",
                  "type": "unit",
                  "file": "backend/tests/test_merge_process.py"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Team Lead as Merge Coordinator",
      "subsections": [
        {
          "title": "Coordinator",
          "requirements": [
            {
              "id": "MG-R020",
              "priority": "P0",
              "area": "Coordinator",
              "text": "The Ollama Team Lead shall serve as the merge coordinator. It shall manage the queue, decide when to trigger rebase/merge, and notify agents. This happens at zero paid-token cost.",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-703"
              ],
              "tests": [
                {
                  "id": "TT-703-01",
                  "task_id": "T-703",
                  "description": "Coordinator loop advances next queued PR when no active merge exists",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-02",
                  "task_id": "T-703",
                  "description": "Event trigger (PR approved) causes immediate queue evaluation",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-03",
                  "task_id": "T-703",
                  "description": "Rebase conflict marks PR as blocked and notifies author + customer",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-04",
                  "task_id": "T-703",
                  "description": "Merge timeout (>10 min) alerts customer",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                }
              ]
            },
            {
              "id": "MG-R021",
              "priority": "P0",
              "area": "Coordinator",
              "text": "The merge coordinator shall poll for merge readiness at a configurable interval (default: 30 seconds). Polling shall check: is anything currently merging? Is the next PR in queue ready? Are CI checks passing?",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-703"
              ],
              "tests": [
                {
                  "id": "TT-703-01",
                  "task_id": "T-703",
                  "description": "Coordinator loop advances next queued PR when no active merge exists",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-02",
                  "task_id": "T-703",
                  "description": "Event trigger (PR approved) causes immediate queue evaluation",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-03",
                  "task_id": "T-703",
                  "description": "Rebase conflict marks PR as blocked and notifies author + customer",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-04",
                  "task_id": "T-703",
                  "description": "Merge timeout (>10 min) alerts customer",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                }
              ]
            },
            {
              "id": "MG-R022",
              "priority": "P1",
              "area": "Coordinator",
              "text": "The merge coordinator shall handle: Rebase conflict (mark PR as blocked, notify author + customer), CI failure after rebase (mark as fixing_comments, notify author), Merge timeout (if > configurable timeout, alert customer).",
              "status": "done",
              "design_ref": "DES-08",
              "tasks": [
                "T-703"
              ],
              "tests": [
                {
                  "id": "TT-703-01",
                  "task_id": "T-703",
                  "description": "Coordinator loop advances next queued PR when no active merge exists",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-02",
                  "task_id": "T-703",
                  "description": "Event trigger (PR approved) causes immediate queue evaluation",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
                },
                {
                  "id": "TT-703-03",
                  "task_id": "T-703",
                  "description": "Rebase conflict marks PR as blocked and notifies author + customer",
                  "type": "unit",
                  "file": "backend/tests/test_coordinator.py"
